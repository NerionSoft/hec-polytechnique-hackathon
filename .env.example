# ─────────────────────────────────────────────────────────────────────────────
# Athena — local environment
#
# Copy to `.env.local` (Next.js auto-loads it) and fill in real values.
# `.env*` files are gitignored except `.env.example` itself.
# Public values must be prefixed `NEXT_PUBLIC_` to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ----------------------------------------------------------------------
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME=Athena

# --- Database (Neon Postgres, pooled URL) -------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# --- Better Auth --------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- AI Gateway (Vercel) ------------------------------------------------------
# https://vercel.com/docs/ai-gateway — unified routing across providers
AI_GATEWAY_API_KEY=
LLM_MODEL=google/gemini-3-flash

# --- Vercel Blob (public bucket for VDR + CSV imports) ------------------------
# Get the token from your Vercel project → Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# --- Optional: Sirene API (free, no key required) -----------------------------
# Override only if you self-host the proxy.
# SIRENE_API_BASE_URL=https://recherche-entreprises.api.gouv.fr

# --- Observability (optional) -------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info
