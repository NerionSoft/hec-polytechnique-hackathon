# ─────────────────────────────────────────────────────────────────────────────
# Athena — local environment
#
# Copy to `.env.local` (Next.js auto-loads it) and fill in real values.
# `.env*` files are gitignored. Public values must be prefixed `NEXT_PUBLIC_`
# to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ----------------------------------------------------------------------
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME=Athena
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- LLM providers (Due Diligence agents, IC memo generation) -----------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Object storage (VDR documents: PDF / XLSX) -------------------------------
AWS_REGION=eu-west-3
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Vector database (citation retrieval, semantic search over the VDR) -------
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Persistence --------------------------------------------------------------
DATABASE_URL=postgresql://athena:athena@localhost:5432/athena
REDIS_URL=redis://localhost:6379

# --- Auth ---------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Observability ------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info
